# 依赖与构建产物
node_modules/
dist/
# build/ 含打包图标（源资产，入库）；其余打包中间物忽略
build/*
!build/icon.icns
!build/icon.png
!build/icon-1024.png
!build/entitlements.mac.plist

# 系统与编辑器
.DS_Store
*.log
.idea/
.vscode/

# 本地运行时（翻箱的收藏/最近记录存在用户主目录，不入库）
.fanbox/

# 终端粘贴临时文件
.fanbox-paste/

# CodeGraph 本地索引（每台机器各自构建，不入库）
.codegraph/

# 验证脚本的临时测试目录
.tmp/

# 验证脚本的截图产物（可复跑重生成，不入库）
experiments/bugfix-202606/shots/

# Windows 资源管理器缩略图缓存
Thumbs.db
Desktop.ini

# 终端录制文件（用户本机数据）
*.cast

# 运行时可能出现的本地凭据 / 配置 / 日志（防御性：用户主目录配置文件不应入仓库）
.env
.env.*
.env.local
.env.*.local

# 截图 / 缩略图缓存（运行时生成，不入库）
screenshots/
thumbnails/
*.png.cache
*.jpg.cache

# Windows 打包产物（dist/ 已覆盖；这里多列一次 dist/win-unpacked/ 防御性）
dist/win-unpacked/
dist/*.exe
dist/*.dmg
dist/*.zip
dist/builder-debug.yml
dist/builder-effective-config.yaml

# 微信 ClawBot 运行时登录态（不入库）
*.ilink-token
ilink-sessions/

# 任何被显式标为本地「不外发」的旁路目录
.fanbox-context/
